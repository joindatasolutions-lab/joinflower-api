# Copia este archivo como .env y ajusta los valores reales.
# La app usa PostgreSQL por defecto en app/database.py.

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=joinflower
DATABASE_USER=postgres
DATABASE_PASSWORD=change-me

# Alternativa: define una URL completa y se ignoraran las variables anteriores.
# DATABASE_URL=postgresql+psycopg2://postgres:change-me@127.0.0.1:5432/joinflower

JWT_SECRET_KEY=change-this-secret
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
